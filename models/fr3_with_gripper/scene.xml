<mujoco model="fr3_with_gripper scene">
  <include file="fr3_with_gripper.xml"/>

  <statistic center="0.4 0 0.4" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="table" rgba="0.8 0.7 0.6 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.0" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" pos="0 0 -0.4" material="groundplane"/>

    <!-- table: surface at z=0, legs down to floor at z=-0.4 -->
    <geom name="table_top"  type="box" size="0.35 0.3 0.02"  pos="0.45 0 -0.02" material="table"/>
    <geom name="table_leg1" type="box" size="0.02 0.02 0.2" pos="0.75  0.25 -0.2" material="table"/>
    <geom name="table_leg2" type="box" size="0.02 0.02 0.2" pos="0.75 -0.25 -0.2" material="table"/>
    <geom name="table_leg3" type="box" size="0.02 0.02 0.2" pos="0.15  0.25 -0.2" material="table"/>
    <geom name="table_leg4" type="box" size="0.02 0.02 0.2" pos="0.15 -0.25 -0.2" material="table"/>

    <!-- front camera -->
    <camera name="front" pos="1.5 0 1.2" xyaxes="0 1 0 -0.633 0 0.774"/>
  </worldbody>
</mujoco>